@page "/workoutplanner"
@layout UserLayout
@inject WorkOutServices workOutservices
@inject UserSessionService userSession
@inject NavigationManager nav
@rendermode InteractiveServer
@using GYM_AND_FITNESS_MANAGEMENT.Models
@using GYM_AND_FITNESS_MANAGEMENT.Services

<div class="page-header">
    <h1>💪 Workout Planner</h1>
    <p>Search exercises and build your workout routine</p>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Log a Workout</span>
    </div>

    <EditForm Model="@workout" OnValidSubmit="HandleWorkOut" FormName="WorkOutForm">
        <div class="form-group" style="position:relative;">
            <label class="form-label">Exercise</label>
            <input type="text" class="form-control"
                   placeholder="Search exercise (e.g. Bench Press)..."
                   value="@searchText"
                   @oninput="FilterExercises" />
            @if (filteredExercises.Count > 0)
            {
                <div class="autocomplete-dropdown">
                    @foreach (var ex in filteredExercises)
                    {
                        <div class="autocomplete-item"
                             @onclick="() => SelectExercise(ex)">
                            @ex.Name
                            <span class="badge badge-info" style="float:right; font-size:11px;">@ex.MuscleGroup</span>
                        </div>
                    }
                </div>
            }
            @if (!string.IsNullOrEmpty(workout.ExerciseName))
            {
                <div style="margin-top:8px; font-size:12px; color:var(--success);">
                    ✅ Selected: <strong>@workout.ExerciseName</strong>
                </div>
            }
        </div>

        <div class="form-row cols-2">
            <div class="form-group">
                <label class="form-label">Sets</label>
                <InputNumber class="form-control" @bind-Value="workout.Sets" placeholder="e.g. 3" />
            </div>
            <div class="form-group">
                <label class="form-label">Reps per Set</label>
                <InputNumber class="form-control" @bind-Value="workout.Reps" placeholder="e.g. 12" />
            </div>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMsg))
        {
            <div class="alert alert-danger">⚠️ @ErrorMsg</div>
        }
        @if (!string.IsNullOrEmpty(SuccessMsg))
        {
            <div class="alert alert-success">✅ @SuccessMsg</div>
        }

        <button type="submit" class="btn btn-primary">💾 Save Workout</button>
    </EditForm>
</div>

@if (recentWorkouts.Count > 0)
{
    <div class="card mt-3">
        <div class="card-header">
            <span class="card-title">Recent Workouts</span>
            <span class="badge badge-success">@recentWorkouts.Count logged</span>
        </div>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Exercise</th>
                        <th>Sets</th>
                        <th>Reps</th>
                        <th>Volume</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (w, i) in recentWorkouts.Select((w, i) => (w, i)))
                    {
                        <tr>
                            <td style="color:var(--text-muted);">@(i+1)</td>
                            <td><strong>@w.ExerciseName</strong></td>
                            <td>@w.Sets</td>
                            <td>@w.Reps</td>
                            <td><span style="color:var(--primary);">@(w.Sets * w.Reps) reps total</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    string ErrorMsg = "";
    string SuccessMsg = "";
    string searchText = "";
    Workout workout = new Workout();
    List<Exercises> exercises = new();
    List<Exercises> filteredExercises = new();
    List<Workout> recentWorkouts = new();

    protected override async Task OnInitializedAsync()
    {
        if (!userSession.IsLoggedIn) { nav.NavigateTo("/login"); return; }
        exercises = await workOutservices.GetAllExercisesAsync();
        recentWorkouts = await workOutservices.GetUserWorkoutsAsync(userSession.UserId);
    }

    void FilterExercises(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";
        workout.ExerciseName = null;

        if (string.IsNullOrWhiteSpace(searchText)) { filteredExercises.Clear(); return; }

        filteredExercises = exercises
            .Where(ex => ex.Name!.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .OrderBy(ex => ex.Name!.StartsWith(searchText, StringComparison.OrdinalIgnoreCase) ? 0 : 1)
            .Take(8).ToList();
    }

    void SelectExercise(Exercises ex)
    {
        workout.ExerciseName = ex.Name;
        searchText = ex.Name!;
        filteredExercises.Clear();
    }

    public async Task HandleWorkOut()
    {
        ErrorMsg = ""; SuccessMsg = "";

        if (string.IsNullOrEmpty(workout.ExerciseName)) { ErrorMsg = "Please search and select an exercise."; return; }
        if (workout.Sets <= 0)  { ErrorMsg = "Please enter a valid number of sets."; return; }
        if (workout.Reps <= 0)  { ErrorMsg = "Please enter a valid number of reps."; return; }

        workout.UserId = userSession.UserId;
        await workOutservices.AddWorkOutAsync(workout);

        recentWorkouts = await workOutservices.GetUserWorkoutsAsync(userSession.UserId);
        SuccessMsg = $"Workout logged! {workout.ExerciseName} — {workout.Sets}×{workout.Reps} 🎉";
        workout = new(); searchText = ""; filteredExercises.Clear();
    }
}
