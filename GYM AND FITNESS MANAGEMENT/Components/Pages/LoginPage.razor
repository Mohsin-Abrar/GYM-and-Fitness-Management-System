@page "/login"
@inject NavigationManager nav
@inject LoginService loginService
@inject UserSessionService userSession
@rendermode InteractiveServer
@using GYM_AND_FITNESS_MANAGEMENT.Models
@using GYM_AND_FITNESS_MANAGEMENT.Services

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="logo-icon">🏋️</div>
            <h2>Welcome Back</h2>
            <p>Sign in to your GymPro account</p>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMsg))
        {
            <div class="alert alert-danger">⚠️ @ErrorMsg</div>
        }

        <div class="form-group">
            <label class="form-label">Email Address</label>
            <input type="email" class="form-control"
                   @bind="Email" @bind:event="oninput"
                   placeholder="you@example.com" />
        </div>
        <div class="form-group">
            <label class="form-label">Password</label>
            <input type="password" class="form-control"
                   @bind="Password" @bind:event="oninput"
                   placeholder="••••••••"
                   @onkeydown="HandleKeyDown" />
        </div>

        <button class="btn btn-primary btn-block btn-lg"
                style="margin-top:8px;"
                @onclick="HandleLogin"
                disabled="@isLoading">
            @(isLoading ? "Signing in..." : "Sign In →")
        </button>

        <div style="text-align:center; margin-top:20px;">
            <span style="font-size:13px; color:var(--text-muted);">Don't have an account? </span>
            <button @onclick="MoveToSignUp" class="btn-link">Create one</button>
        </div>
    </div>
</div>

@code {
    string Email = "";
    string Password = "";
    string ErrorMsg = "";
    bool isLoading = false;

    async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    async Task HandleLogin()
    {
        if (isLoading) return;
        ErrorMsg = "";

        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMsg = "Please enter your email and password.";
            return;
        }

        isLoading = true;
        StateHasChanged();

        string? redirectUrl = null;

        try
        {
            // Single DB call — returns user row including Role column
            var user = await loginService.ValidateLogin(Email.Trim(), Password);

            if (user != null)
            {
                // Store session with role from database
                userSession.Login(user.Id, user.Email!, user.Name!, user.Role);

                // Role comes from DB — Admin goes to admin dashboard, User goes to user dashboard
                redirectUrl = user.IsAdmin ? "/admindashboard" : "/userdashboard";
            }
            else
            {
                ErrorMsg = "Invalid email or password. Please try again.";
            }
        }
        catch
        {
            ErrorMsg = "An error occurred. Please try again.";
        }
        finally
        {
            isLoading = false;
        }

        // Navigate outside try/catch so Blazor handles it cleanly
        if (redirectUrl != null)
            nav.NavigateTo(redirectUrl, forceLoad: true);
    }

    void MoveToSignUp() => nav.NavigateTo("/signup");
}
