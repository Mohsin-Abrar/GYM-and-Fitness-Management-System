@inherits LayoutComponentBase
@inject UserSessionService userSession
@inject NavigationManager nav
@using GYM_AND_FITNESS_MANAGEMENT.Services

<div class="app-shell">
    <div class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">🏋️</div>
            <div>
                <div class="brand-name">GymPro</div>
                <div class="brand-sub">Admin Panel</div>
            </div>
        </div>
        <nav class="sidebar-nav">
            <a href="/admindashboard" class="nav-item">
                <span class="nav-icon">📊</span> Dashboard
            </a>
            <a href="/addmember" class="nav-item">
                <span class="nav-icon">➕</span> Add Member
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="/" @onclick="HandleLogout" @onclick:preventDefault class="nav-item">
                <span class="nav-icon">🚪</span> Logout
            </a>
        </div>
    </div>
    <div class="main-content">
        @Body
    </div>
</div>

@code {
    void HandleLogout()
    {
        userSession.Logout();
        nav.NavigateTo("/login", forceLoad: true);
    }
}
